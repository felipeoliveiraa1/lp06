---
// Layout das páginas de funil (upsell/downsell). Mesmo design system + tracking
// da principal, porém enxuto: só pré-carrega o poster da VSL desta página.
import '../styles/global.css';
const { title = 'A Sociedade Trader', poster } = Astro.props;
---
<!doctype html>
<html lang="pt-BR">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />

<!-- GTM como 1º script (PageView cedo = connect rate); sem preload de alta
     prioridade p/ não disputar o LCP. -->
<link rel="preconnect" href="https://www.googletagmanager.com" />
<!-- Google Tag Manager -->
<script is:inline>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
})(window,document,'script','dataLayer','GTM-K569RL73');</script>
<!-- End Google Tag Manager -->

<title>{title}</title>
<meta name="robots" content="noindex,nofollow" />
<link rel="icon" href="/favicon.svg" type="image/svg+xml" />

<!-- vturb optimizer: marca o relógio do player o quanto antes -->
<script is:inline>!function(i,n){i._plt=i._plt||(n&&n.timeOrigin?n.timeOrigin+n.now():Date.now())}(window,performance);</script>

<!-- abre conexões cedo (VSL) -->
<link rel="preconnect" href="https://scripts.converteai.net" crossorigin />
<link rel="preconnect" href="https://cdn.converteai.net" crossorigin />
<link rel="preconnect" href="https://images.converteai.net" crossorigin />
<link rel="dns-prefetch" href="https://license.vturb.com" />
<!-- fonte da marca -->
<link rel="preload" as="font" type="font/woff2" crossorigin href="/assets/InstrumentSans-600.woff2" />
<link rel="preload" as="font" type="font/woff2" crossorigin href="/assets/InstrumentSans-500.woff2" />
{poster && <link rel="preload" as="image" href={poster} fetchpriority="high" />}
</head>
<body>
<!-- Google Tag Manager (noscript) -->
<noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-K569RL73" height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
<!-- End Google Tag Manager (noscript) -->
<slot />
<!-- countdown de escassez (roda só se houver #cd; para em 00:00) -->
<script is:inline>
  (function(){var el=document.getElementById('cd');if(!el)return;var t=15*60;
   (function tick(){var m=Math.floor(t/60),s=t%60;el.textContent=m+':'+(s<10?'0':'')+s;
    if(t>0){t--;setTimeout(tick,1000);}})();})();
</script>
</body>
</html>
