---
import '../styles/global.css';
const { title = 'AL – BIO – A Sociedade Trader' } = Astro.props;
---
<!doctype html>
<html lang="pt-BR">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />

<!-- GTM como 1º script (dispara o PageView cedo = connect rate). preconnect aquece
     a conexão. Sem preload de alta prioridade: o gtm.js carrega async/cedo sem
     disputar o slot de rede da imagem do hero (LCP) -> mantém a nota mais alta. -->
<link rel="preconnect" href="https://www.googletagmanager.com" />
<!-- Google Tag Manager -->
<script is:inline>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
})(window,document,'script','dataLayer','GTM-K569RL73');</script>
<!-- End Google Tag Manager -->

<!-- VK Digital Pixel (sales + page_view) — só na home/principal -->
<link rel="dns-prefetch" href="https://cf.vkdigital.com.br" />
<script is:inline>
!function(w,d,c,u){
  (w.vkPixelSales=w.vkPixelSales||{_q:[]})._q.push(['init',c]);
  (w.vkPageViewPixel=w.vkPageViewPixel||{_q:[]})._q.push(['init',c,'page_view']);
  ['https://cf.vkdigital.com.br/sales_pixel.js?v=56','https://cf.vkdigital.com.br/event_pageview.js'].forEach(function(src,i){
    var s=d.createElement('script');
    s.src=src;
    s.async=1;
    if(i===0) {
      s.setAttribute('data-no-xcod-url','');
    }
    d.head.appendChild(s);
  });
}(window,document,'mZe47LW6iR4rZuYoskrW');
</script>
<!-- End VK Digital Pixel -->

<title>{title}</title>
<meta name="robots" content="max-image-preview:large" />
<link rel="icon" href="/favicon.svg" type="image/svg+xml" />

<!-- vturb optimizer: marca o relógio do player o quanto antes (otimizador oficial) -->
<script is:inline>!function(i,n){i._plt=i._plt||(n&&n.timeOrigin?n.timeOrigin+n.now():Date.now())}(window,performance);</script>

<!-- open connections early (VSL stream) -->
<link rel="preconnect" href="https://scripts.converteai.net" crossorigin />
<link rel="preconnect" href="https://cdn.converteai.net" crossorigin />
<link rel="preconnect" href="https://images.converteai.net" crossorigin />
<link rel="dns-prefetch" href="https://license.vturb.com" />
<!-- brand font (preloaded so headings paint instantly) -->
<link rel="preload" as="font" type="font/woff2" crossorigin href="/assets/InstrumentSans-600.woff2" />
<link rel="preload" as="font" type="font/woff2" crossorigin href="/assets/InstrumentSans-500.woff2" />
<!-- above-the-fold images = LCP candidates (hero bg + poster da VSL) -->
<link rel="preload" as="image" href="/assets/hero-bg.webp" fetchpriority="high" />
<link rel="preload" as="image" href="/assets/poster-vsl.webp" fetchpriority="high" />
</head>
<body>
<!-- Google Tag Manager (noscript) -->
<noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-K569RL73" height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
<!-- End Google Tag Manager (noscript) -->
<slot />
</body>
</html>
